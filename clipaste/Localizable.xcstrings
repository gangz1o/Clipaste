    "Hold %@ while copying or pasting to force plain text output." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Halten Sie %@ beim Kopieren oder Einfügen gedrückt, um reinen Text zu erzwingen."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Maintenez %@ pendant la copie ou le collage pour forcer le texte brut."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "コピーまたは貼り付け中に %@ を押したままにするとプレーンテキストを強制します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "복사 또는 붙여넣을 때 %@을(를) 누른 채로 두면 서식 없는 텍스트로 강제합니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "复制或粘贴时按住 %@ 可强制输出纯文本。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "拷貝或貼上時按住 %@ 可強制輸出純文字。"
          }
        }
      }
    },
    "Hold Option and double-click to temporarily reverse the current text format setting." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Halten Sie die Wahltaste gedrückt und doppelklicken Sie, um das aktuelle Textformat vorübergehend umzukehren."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Maintenez Option et double-cliquez pour inverser temporairement le format de texte actuel."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Option キーを押しながらダブルクリックすると、テキストフォーマット設定を一時的に反転できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Option 키를 누른 채 두 번 클릭하면 현재 텍스트 형식 설정을 일시적으로 반전할 수 있습니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "按住 Option 键并双击列表条目，可臨时反轉目前的文字格式设置。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "按住 Option 鍵並雙擊列表條目，可臨時反轉目前的文字格式設定。"
          }
        }
      }
    },
    "Hold the modifier key while clicking an item to trigger the corresponding action." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Halten Sie die Sondertaste gedrückt, während Sie auf ein Element klicken, um die entsprechende Aktion auszulösen."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Maintenez la touche de modification en cliquant sur un élément pour déclencher l'action correspondante."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "項目をクリックする際に修飾キーを押し続けると、対応するアクションが実行されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "항목을 클릭할 때 수정 키를 누르고 있으면 해당 작업이 실행됩니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "点击项目时按住修饰键可触发对应操作。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "點擊項目時按住修飾鍵可觸發對應操作。"
          }
        }
      }
    },
    "Hold the quick paste modifier to reveal 1…9 shortcuts. Hold the plain text modifier while copying or pasting to strip formatting." : {
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
