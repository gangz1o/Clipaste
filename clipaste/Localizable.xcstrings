    "Always reset the search field each time the clipboard history panel opens." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Setzt das Suchfeld jedes Mal zurück, wenn der Verlauf der Zwischenablage geöffnet wird."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Réinitialise toujours le champ de recherche chaque fois que le panneau d'historique du presse-papiers s'ouvre."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "クリップボード履歴パネルを開くたびに検索フィールドをリセットします。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "클립보드 기록 패널을 열 때마다 검색 필드를 항상 초기화합니다."
