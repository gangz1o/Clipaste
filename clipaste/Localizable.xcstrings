    "Permanently deletes all clipboard records and image caches. This cannot be undone." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Löscht dauerhaft alle Zwischenablagen-Einträge und Bildcaches. Dies kann nicht rückgängig gemacht werden."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Supprime définitivement tous les enregistrements et caches d'images. Irréversible."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "すべてのクリップボード記録と画像キャッシュを完全に削除します。この操作は元に戻せません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "모든 클립보드 기록과 이미지 캐시를 영구적으로 삭제합니다. 취소할 수 없습니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "永久删除所有剪贴板记录和图片缓存，此操作无法撤销。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "將永久刪除所有剪貼板記錄及相關圖片快取，且無法復原。"
          }
        }
      }
    },
    "Permanently deletes non-favorite clipboard records and image caches. Items in Favorites are kept." : {
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
