    },
    "Choose the iCopy SQLite database file. Clipaste will import the text history into your current library." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wähle die SQLite-Datenbankdatei von iCopy aus. Clipaste importiert den Textverlauf in deine aktuelle Mediathek."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Choisissez le fichier de base de données SQLite d’iCopy. Clipaste importera l'historique textuel dans votre bibliothèque actuelle."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iCopy の SQLite データベースファイルを選択すると、Clipaste がテキスト履歴を現在のライブラリに取り込みます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iCopy SQLite 데이터베이스 파일을 선택하면 Clipaste가 텍스트 기록을 현재 라이브러리로 가져옵니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "选择 iCopy 的 SQLite 数据库文件后，Clipaste 会将文本历史导入当前资料库。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "選擇 iCopy 的 SQLite 資料庫檔案後，Clipaste 會將文字歷史匯入目前資料庫。"
          }
        }
      }
    },
    "Choose the Paste SQLite database file. Clipaste will import the history records into your current library." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
