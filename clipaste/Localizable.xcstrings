      }
    },
    "Choose the PasteNow exported JSON file. Clipaste will parse the history items and import them into your current library." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wähle die exportierte JSON-Datei von PasteNow aus. Clipaste analysiert die Verlaufseinträge und importiert sie in deine aktuelle Mediathek."
